# infra/.env.example
# Copiar a .env y completar con valores reales antes de levantar Docker.
# NUNCA commitear el archivo .env con valores reales.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambiar-por-una-clave-segura-de-50-caracteres
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DB_NAME=lambda_dashboard
DB_USER=postgres
DB_PASSWORD=cambiar-por-password-seguro
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS (orígenes permitidos para el frontend) ───────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Email (opcional, para envío de reportes) ──────────────────────────────────
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=tu-api-key-sendgrid
